<assembly>
    <id>assembly</id>
    <formats>
        <format>tar.gz</format>
    </formats>
    <includeBaseDirectory>true</includeBaseDirectory>
    <fileSets>
        <fileSet>
            <directory>src/main/resources/deploy</directory>
            <includes>
                <include>*.sh</include>
            </includes>
            <excludes>
                <exclude>uncompress.sh</exclude>
            </excludes>
            <outputDirectory>bin</outputDirectory>
            <fileMode>0755</fileMode>
        </fileSet>
        <fileSet>
            <directory>src/main/resources</directory>
            <includes>
                <include>*.yml</include>
            </includes>
            <outputDirectory>apps/${project.artifactId}/config</outputDirectory>
        </fileSet>
        <fileSet>
            <directory>src/main/sql</directory>
            <includes>
                <include>*.sql</include>
            </includes>
            <outputDirectory>apps/${project.artifactId}/sql</outputDirectory>
        </fileSet>
        <fileSet>
            <directory>target/classes/</directory>
            <includes>
                <include>*.properties</include>
                <include>*.yml</include>
                <include>*.xml</include>
                <include>*.txt</include>
            </includes>
            <outputDirectory>apps/${project.artifactId}/config</outputDirectory>
        </fileSet>
    </fileSets>
    <files>
        <file>
            <source>target/${project.artifactId}-${project.version}.jar</source>
            <destName>${project.artifactId}-${project.version}.jar</destName>
            <outputDirectory>apps/${project.artifactId}</outputDirectory>
        </file>
    </files>
