<?xml version="1.0" encoding="UTF-8"?>

<configuration debug="false" scan="false"  packagingData="true">
    <trafficBackupProperty scope="context" name="logPath" source="JM.LOG.PATH"/>
    <trafficBackupProperty scope="context" name="logFileSize" source="JM.LOG.FILE.SIZE" defaultValue="200MB"/>
    <trafficBackupProperty scope="context" name="backupConfigLogLevel" source="cn.lezoo.white-list.backup.level" defaultValue="info"/>
    <trafficBackupProperty scope="context" name="logRetainDays" source="cn.lezoo.white-list.backup.retainDays" defaultValue="30"/>
    <trafficBackupProperty scope="context" name="enableAsync" source="cn.lezoo.white-list.backup.enableAsync" defaultValue="false"/>
    <jvmContext scope="context" name="pid"/>


    <appender name="BACKUP_LOG_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${logPath}/backup/messageInfo-${APP_NAME}-${pid}.log</file>

        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${logPath}/backup/messageInfo-${APP_NAME}-${pid}.log.%d{yyyy-MM-dd}.zip</fileNamePattern>
            <!-- 设置最大历史记录天数，超过指定天数的日志文件将被删除，默认值为0（即不删除） -->
            <maxHistory>${logRetainDays}</maxHistory>
        </rollingPolicy>

        <encoder>
            <Pattern>%date [%contextName] %level [%thread] %logger{36} [%file : %line] %msg%n</Pattern>
        </encoder>
    </appender>

    <!-- 异步输出 -->
    <appender name="BACKUP-ASYNC" class="ch.qos.logback.classic.AsyncAppender">
        <!-- 不丢失日志.默认的,如果队列的80%已满,则会丢弃TRACT、DEBUG、INFO级别的日志 -->
        <discardingThreshold>0</discardingThreshold>
        <!-- 更改默认的队列的深度,该值会影响性能.默认值为256 -->
        <queueSize>512</queueSize>
        <!-- 添加附加的appender,最多只能添加一个 -->
        <appender-ref ref="BACKUP_LOG_FILE"/>
    </appender>

    <if condition='property("enableAsync").equals("true")'>
        <then>
            <logger name="cn.lezoo.doux.white.list.diversion.http.util.TrafficBackupUtils"
                    level="${backupConfigLogLevel}"
                    additivity="false">
                <appender-ref ref="BACKUP-ASYNC"/>
            </logger>
        </then>
        <else>
            <logger name="cn.lezoo.doux.white.list.diversion.http.util.TrafficBackupUtils"
                    level="${backupConfigLogLevel}"
                    additivity="false">
                <appender-ref ref="BACKUP_LOG_FILE"/>
            </logger>
        </else>
    </if>
</configuration>