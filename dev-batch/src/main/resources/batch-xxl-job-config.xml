<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">
    <bean id="xxlJobSpringExecutor" class="com.xxl.job.core.executor.impl.XxlJobSpringExecutor">
        <property name="adminAddresses" value="${dev.batch.xxl.job.admin-address}"/>
        <property name="appname" value="${dev.batch.xxl.job.app-name}"/>
        <property name="address" value="${dev.batch.xxl.job.address:}"/>
        <property name="ip" value="${dev.batch.xxl.job.ip:}"/>
        <property name="port" value="${dev.batch.xxl.job.port}"/>
        <property name="accessToken" value="${dev.batch.xxl.job.access-token:}"/>
        <property name="logPath" value="${dev.batch.xxl.job.log-path:data/applogs/xxl-job/jobhandler}"/>
        <property name="logRetentionDays" value="${dev.batch.xxl.job.log-rentention-days:30}"/>
    </bean>
</beans>