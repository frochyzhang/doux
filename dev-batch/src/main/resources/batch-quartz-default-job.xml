<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- 定时任务配置 开始 -->
    <bean id="quartzManagerBean" class="com.allinfinance.dev.batch.quartz.QuartzManager"/>
    <bean id="quartzManagerJobDetail" class="org.springframework.scheduling.quartz.MethodInvokingJobDetailFactoryBean">
        <property name="targetObject" ref="quartzManagerBean"/>
        <!-- 定时执行的类方法 -->
        <property name="targetMethod" value="reScheduleJob"/>
        <property name="concurrent" value="false"/>
    </bean>
    <bean id="quartzManagerTrigger" class="org.springframework.scheduling.quartz.SimpleTriggerFactoryBean">
        <!-- 这里不可以直接在属性jobDetail中引用taskJob，因为他要求的是一个jobDetail类型的对象，所以我们得通过MethodInvokingJobDetailFactoryBean来转一下 -->
        <property name="jobDetail" ref="quartzManagerJobDetail"/>
        <!-- 延时1秒钟 执行任务 -->
        <property name="startDelay" value="1000"/>
        <!-- 任务执行周期 2分钟 -->
        <property name="repeatInterval" value="60000"/>
    </bean>

    <!--自定义可注入的JobFactory -->
    <bean id="customJobFactory" class="com.allinfinance.dev.batch.quartz.QuartzCustomJobFactory"/>

    <!-- 触发器工厂，将所有的定时任务都注入工厂-->
    <bean id="schedulerFactory" lazy-init="false" autowire="no"
          class="org.springframework.scheduling.quartz.SchedulerFactoryBean">
        <!-- 添加触发器 -->
        <property name="triggers">
            <list>
                <!-- 将上面定义的测试定时任务注入（可以定义多个定时任务，同时注入）-->
                <!--                <ref local="quartzManagerTrigger"/>-->
                <ref bean="quartzManagerTrigger"/>
            </list>
        </property>
        <property name="jobFactory" ref="customJobFactory"/>
    </bean>

    <bean id="quartzManageService" class="com.allinfinance.dev.batch.quartz.QuartzBatchServiceImpl"
          lazy-init="false">
        <property name="scheduler" ref="schedulerFactory"/>
    </bean>


    <!-- 定时任务配置 结束 -->
</beans>