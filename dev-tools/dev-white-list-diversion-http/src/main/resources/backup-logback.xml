<?xml version="1.0" encoding="UTF-8"?>

<configuration debug="false" scan="false"  packagingData="true">
    <trafficBackupProperty scope="context" name="logPath" source="JM.LOG.PATH"/>
    <trafficBackupProperty scope="context" name="logRetainCount" source="JM.LOG.RETAIN.COUNT" defaultValue="7"/>
    <trafficBackupProperty scope="context" name="logFileSize" source="JM.LOG.FILE.SIZE" defaultValue="200MB"/>
    <trafficBackupProperty scope="context" name="backupConfigLogLevel" source="com.allinfinance.dev.white.list.diversion.level" defaultValue="info"/>


    <appender name="BACKUP_LOG_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${logPath}/${APP_NAME}/${APP_NAME}-backup.log</file>

        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${logPath}/${APP_NAME}/${APP_NAME}-backup.log.%d{yyyy-MM-dd}.%i.zip</fileNamePattern>
            <maxFileSize>200MB</maxFileSize>
        </rollingPolicy>

        <encoder>
            <Pattern>%date [%contextName] %level [%thread] %logger{36} [%file : %line] %msg%n</Pattern>
        </encoder>
    </appender>

    <!-- 异步输出 -->
    <appender name="BACKUP-ASYNC" class="ch.qos.logback.classic.AsyncAppender">
        <!-- 不丢失日志.默认的,如果队列的80%已满,则会丢弃TRACT、DEBUG、INFO级别的日志 -->
        <discardingThreshold>0</discardingThreshold>
        <!-- 更改默认的队列的深度,该值会影响性能.默认值为256 -->
        <queueSize>512</queueSize>
        <!-- 添加附加的appender,最多只能添加一个 -->
        <appender-ref ref="BACKUP_LOG_FILE"/>
    </appender>

    <logger name="com.allinfinance.dev.white.list.diversion.http.backup.TrafficBackupUtils" level="${backupConfigLogLevel}"
            additivity="false">
        <appender-ref ref="BACKUP-ASYNC"/>
    </logger>
</configuration>