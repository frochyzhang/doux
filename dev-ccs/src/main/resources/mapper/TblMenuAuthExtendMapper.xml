<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.allinfinance.dev.ccs.dal.mapper.TblMenuAuthMapper">
    <resultMap id="BaseResultMap" type="com.allinfinance.dev.ccs.dal.model.TblMenuAuth">
        <constructor>
            <idArg column="AUTH_ID" javaType="java.lang.String" jdbcType="VARCHAR"/>
            <idArg column="MENU_ID" javaType="java.lang.String" jdbcType="VARCHAR"/>
            <arg column="IS_AVAILABLE" javaType="java.lang.String" jdbcType="VARCHAR"/>
            <arg column="CREATE_TIME" javaType="java.util.Date" jdbcType="TIMESTAMP"/>
            <arg column="CREATE_BY" javaType="java.lang.String" jdbcType="VARCHAR"/>
            <arg column="UPDATE_TIME" javaType="java.util.Date" jdbcType="TIMESTAMP"/>
            <arg column="UPDATE_BY" javaType="java.lang.String" jdbcType="VARCHAR"/>
            <arg column="RESERVED_FIELD1" javaType="java.lang.String" jdbcType="VARCHAR"/>
            <arg column="RESERVED_FIELD2" javaType="java.lang.String" jdbcType="VARCHAR"/>
            <arg column="RESERVED_FIELD3" javaType="java.lang.String" jdbcType="VARCHAR"/>
        </constructor>
    </resultMap>
    <select id="selectBatchIds" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from TBL_MENU_AUTH
        where AUTH_ID in
        <foreach close=")" collection="authIds" index="index" item="authId" open="(" separator=",">
            #{authId}
        </foreach>
    </select>
</mapper>