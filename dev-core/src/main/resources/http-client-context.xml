<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean id="httpConnectionManager" class="com.allinfinance.dev.core.util.http.client.HttpConnectionManager"
          init-method="init">
        <property name="maxPoolSize" value="${dev.http.maxPoolSize}"/>
        <property name="initPoolSize" value="${dev.http.initPoolSize}"/>
        <property name="charSet" value="${dev.http.charSet}"/>
        <property name="socketSoTimeOut" value="${dev.http.socketSoTimeOut}"/>
    </bean>
</beans>