<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:dubbo="http://dubbo.apache.org/schema/dubbo"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
       http://dubbo.apache.org/schema/dubbo http://dubbo.apache.org/schema/dubbo/dubbo.xsd">

    <!-- 提供方应用信息，用于计算依赖关系 -->
    <dubbo:application name="${dev.dubbo.application.name}"/>

    <!-- 使用zookeeper注册中心暴露服务地址 -->
    <dubbo:registry address="${dev.dubbo.registry.address}" protocol="${dev.dubbo.registry.protocol}"
                    timeout="${dev.dubbo.registry.timeout}"/>

    <!-- 用dubbo协议在20880端口暴露服务 -->
    <dubbo:protocol name="${dev.dubbo.protocol.name}" port="${dev.dubbo.protocol.port}"/>

    <dubbo:provider timeout="${dev.dubbo.provider.timeout}" retries="${dev.dubbo.provider.retries}"/>

    <dubbo:consumer check="${dev.dubbo.consumer.check}" timeout="${dev.dubbo.consumer.timeout}"
                    retries="${dev.dubbo.consumer.retries}"/>
</beans>