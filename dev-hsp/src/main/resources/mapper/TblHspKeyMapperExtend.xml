<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.allinfinance.dev.hsp.mapper.TblHsmKeyMapper">
    <select id="selectByKeyIndex" parameterType="java.lang.String" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from TBL_HSM_KEY
        where KEY_INDEX = #{keyIndex,jdbcType=VARCHAR}
    </select>
</mapper>